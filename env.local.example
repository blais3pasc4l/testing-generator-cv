# Copia este archivo a .env.local y rellena los valores (para desarrollo local)
# En Vercel los pones en Settings → Environment Variables

# Contraseña que usarás para entrar a la app
APP_PASSWORD=cambiame-por-una-contrasena-fuerte

# Secreto para firmar las cookies de sesión (cualquier string largo aleatorio)
# Puedes generar uno con: openssl rand -base64 32
SESSION_SECRET=genera-una-cadena-larga-y-aleatoria-aqui-de-al-menos-32-caracteres

# Tu API key de Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (lo rellenarás automáticamente al conectar el integration en Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=
